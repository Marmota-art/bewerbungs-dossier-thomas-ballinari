# Google AI Studio / Gemini API (für den Chatbot «Frag Thomas»)
# Key erstellen: https://aistudio.google.com/apikey
# Kopieren Sie diese Datei nach .env.local und tragen Sie Ihren echten Key ein:
#   copy .env.example .env.local   (Windows)
#   cp .env.example .env.local     (Mac/Linux)
GEMINI_API_KEY=your_api_key_here

# Optional: anderes Modell (Standard: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Netlify / Produktion (PFLICHT für echten Gemini-Chat live):
#   Netlify → Site configuration → Environment variables → GEMINI_API_KEY = Ihr Key
#   Danach: Deploys → Trigger deploy → Deploy site
# Ohne Key: Backup-Antworten aus der Lebenslauf-Wissensdatenbank (kein Gemini).
# Nicht ins Git committen!

# APP_URL: Wird von AI Studio bei Cloud-Deployments gesetzt (optional lokal)
APP_URL=http://localhost:3000

# Optional: Geschützter Bewerbungszugang (seriös für Monads & HR)
# Wenn gesetzt, erscheint ein Zugangscode-Fenster. Key nur im Netlify-Dashboard setzen, nicht committen!
# Link in der Mail: https://thomoro.com/einstieg.html (Zugangscode separat mitteilen)
# SITE_ACCESS_KEY=your-access-code-here
